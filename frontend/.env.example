# TechStore Frontend - Environment Variables Template

# URL of the Backend API Server
NEXT_PUBLIC_API_URL=http://localhost:5000

# URL of the Backend Socket.io Server (for real-time chat)
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Base URL of the Frontend Client (used for SEO Sitemap metadata generation)
NEXT_PUBLIC_CLIENT_URL=http://localhost:3000
