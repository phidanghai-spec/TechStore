# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MySQL)
# Thay đổi root và YOUR_PASSWORD thành thông tin tài khoản MySQL của bạn
DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/techstore"

# JWT Authentication
JWT_SECRET="techstore_jwt_secret_key_for_development"
JWT_EXPIRES_IN="30d"

# Nodemailer / Email Service
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"

# CORS configuration
FRONTEND_URL="http://localhost:3000"

# Anthropic Claude AI (RAG Chatbot)
# Lấy API key tại: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"

# Render.com (production keep-alive ping)
RENDER_URL="https://your-backend.onrender.com"
